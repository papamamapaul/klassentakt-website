---
import { APP_URL } from '../config';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'KlassenTakt — Intelligente Stundenplanung f\u00fcr Schulen' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | KlassenTakt</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <!-- Header -->
    <header class="border-b border-gray-100">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900">
          <svg class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          KlassenTakt
        </a>
        <nav class="flex items-center gap-6">
          <a href="/preise" class="text-sm text-gray-600 hover:text-gray-900">Preise</a>
          <a href="/blog" class="text-sm text-gray-600 hover:text-gray-900">Blog</a>
          <a href={`${APP_URL}/login`} class="text-sm text-gray-600 hover:text-gray-900">Anmelden</a>
          <a href={`${APP_URL}/register`} class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Kostenlos starten
          </a>
        </nav>
      </div>
    </header>

    <!-- Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 bg-gray-50">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div>
            <h3 class="font-semibold text-gray-900">KlassenTakt</h3>
            <p class="mt-2 text-sm text-gray-500">Intelligente Stundenplanung f\u00fcr Schulen. Erstellt mit KI-gest\u00fctzter Optimierung.</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">Produkt</h3>
            <ul class="mt-2 space-y-1 text-sm text-gray-500">
              <li><a href="/preise" class="hover:text-gray-900">Preise</a></li>
              <li><a href="/blog" class="hover:text-gray-900">Blog</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">Rechtliches</h3>
            <ul class="mt-2 space-y-1 text-sm text-gray-500">
              <li><a href="/impressum" class="hover:text-gray-900">Impressum</a></li>
              <li><a href="/datenschutz" class="hover:text-gray-900">Datenschutz</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-gray-400">
          &copy; {new Date().getFullYear()} KlassenTakt. Alle Rechte vorbehalten.
        </div>
      </div>
    </footer>
  </body>
</html>
