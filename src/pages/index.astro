---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APP_URL, tiers } from '../config';
---

<BaseLayout title="Stundenplanung leicht gemacht">
  <!-- Hero -->
  <section class="bg-gradient-to-b from-blue-50 to-white">
    <div class="mx-auto max-w-6xl px-6 py-24 text-center">
      <h1 class="text-5xl font-extrabold tracking-tight text-gray-900">
        Stundenplanung<br />
        <span class="text-blue-600">leicht gemacht</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
        KlassenTakt erstellt optimale Stundenpläne für Ihre Schule —
        automatisch, regelbasiert und in Minuten statt Tagen.
      </p>
      <div class="mt-8 flex justify-center gap-4">
        <a
          href={`${APP_URL}/register`}
          class="rounded-lg bg-blue-600 px-6 py-3 text-lg font-semibold text-white shadow-lg hover:bg-blue-700"
        >
          Kostenlos starten
        </a>
        <a
          href="/preise"
          class="rounded-lg border border-gray-300 px-6 py-3 text-lg font-semibold text-gray-700 hover:bg-gray-50"
        >
          Preise ansehen
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-400">Keine Kreditkarte nötig · Free-Plan dauerhaft kostenlos</p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold text-gray-900">So funktioniert's</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600">
        In drei Schritten zum fertigen Stundenplan
      </p>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-2xl font-bold text-blue-600">1</div>
          <h3 class="text-lg font-semibold">Stammdaten erfassen</h3>
          <p class="mt-2 text-sm text-gray-600">Lehrkräfte, Klassen, Fächer und Räume anlegen — oder Beispieldaten importieren.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-2xl font-bold text-blue-600">2</div>
          <h3 class="text-lg font-semibold">Regeln konfigurieren</h3>
          <p class="mt-2 text-sm text-gray-600">Wählen Sie aus 25+ Regeln: Keine Hohlstunden, Doppelstunden, Nachmittagsregelungen und mehr.</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100 text-2xl font-bold text-blue-600">3</div>
          <h3 class="text-lg font-semibold">Plan generieren</h3>
          <p class="mt-2 text-sm text-gray-600">Der KI-Solver erstellt den optimalen Plan. Manuell nachjustieren per Drag & Drop.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Preview -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center text-3xl font-bold text-gray-900">Einfache, faire Preise</h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600">
        Starten Sie kostenlos. Upgraden Sie wenn Ihre Schule wächst.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {tiers.map((t) => (
          <div class={`rounded-xl border-2 bg-white p-6 ${t.highlight ? 'border-blue-600 shadow-lg' : 'border-gray-200'}`}>
            {t.highlight && <div class="mb-3 inline-block rounded-full bg-blue-600 px-3 py-1 text-xs font-semibold text-white">Empfohlen</div>}
            <h3 class="text-xl font-bold">{t.name}</h3>
            <p class="mt-1 text-sm text-gray-500">{t.description}</p>
            <div class="mt-4 text-3xl font-extrabold">
              {t.priceLabel}
            </div>
            <ul class="mt-6 space-y-2">
              {t.features.map((f) => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="h-4 w-4 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={t.tier === 'professional' ? 'mailto:kontakt@klassentakt.de' : `${APP_URL}/register`}
              class={`mt-6 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold ${t.highlight ? 'bg-blue-600 text-white hover:bg-blue-700' : 'border border-gray-300 text-gray-700 hover:bg-gray-50'}`}
            >
              {t.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-bold text-gray-900">Bereit, loszulegen?</h2>
      <p class="mt-4 text-gray-600">Erstellen Sie Ihren ersten Stundenplan in unter 10 Minuten.</p>
      <a
        href={`${APP_URL}/register`}
        class="mt-6 inline-block rounded-lg bg-blue-600 px-8 py-3 text-lg font-semibold text-white shadow-lg hover:bg-blue-700"
      >
        Kostenlos starten
      </a>
    </div>
  </section>
</BaseLayout>
