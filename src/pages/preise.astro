---
import BaseLayout from '../layouts/BaseLayout.astro';
import { APP_URL, tiers } from '../config';
---

<BaseLayout title="Preise" description="Faire Preise f\u00fcr jede Schulgr\u00f6\u00dfe. Starten Sie kostenlos.">
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="text-center text-4xl font-bold text-gray-900">Preise</h1>
      <p class="mx-auto mt-4 max-w-2xl text-center text-gray-600">
        Starten Sie kostenlos. Upgraden Sie jederzeit.
      </p>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {tiers.map((t) => (
          <div class={`rounded-xl border-2 bg-white p-8 ${t.highlight ? 'border-blue-600 shadow-lg relative' : 'border-gray-200'}`}>
            {t.highlight && <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue-600 px-4 py-1 text-xs font-semibold text-white">Empfohlen</div>}
            <h2 class="text-2xl font-bold">{t.name}</h2>
            <p class="mt-2 text-sm text-gray-500">{t.description}</p>
            <div class="mt-6 text-4xl font-extrabold">
              {t.priceLabel}
            </div>
            <ul class="mt-8 space-y-3">
              {t.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={t.tier === 'professional' ? 'mailto:kontakt@klassentakt.de' : `${APP_URL}/register`}
              class={`mt-8 block rounded-lg px-4 py-3 text-center text-sm font-semibold ${t.highlight ? 'bg-blue-600 text-white hover:bg-blue-700' : 'border border-gray-300 text-gray-700 hover:bg-gray-50'}`}
            >
              {t.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <div class="mx-auto mt-20 max-w-3xl">
        <h2 class="text-center text-2xl font-bold text-gray-900">H&auml;ufige Fragen</h2>
        <div class="mt-8 space-y-6">
          <div>
            <h3 class="font-semibold text-gray-900">Kann ich jederzeit upgraden?</h3>
            <p class="mt-1 text-sm text-gray-600">Ja, Sie k&ouml;nnen jederzeit auf ein h&ouml;heres Paket wechseln. Die &Auml;nderung wird sofort wirksam.</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">Gibt es eine Mindestlaufzeit?</h3>
            <p class="mt-1 text-sm text-gray-600">Nein, alle Pakete sind monatlich k&uuml;ndbar. Keine langfristigen Vertr&auml;ge.</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">Was passiert mit meinen Daten wenn ich downgrade?</h3>
            <p class="mt-1 text-sm text-gray-600">Ihre Daten bleiben erhalten. Bestimmte Features werden nur gesperrt, nichts wird gel&ouml;scht.</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">Bieten Sie Rabatte f&uuml;r Schulen an?</h3>
            <p class="mt-1 text-sm text-gray-600">Wir bieten ein Beta-Tester-Programm: Voller Funktionsumfang kostenlos gegen qualitatives Feedback. Kontaktieren Sie uns!</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
