---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog" description="Tipps und Neuigkeiten rund um Stundenplanung">
  <section class="py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
      <p class="mt-4 text-gray-600">Tipps, Neuigkeiten und Best Practices für die Stundenplanung.</p>

      <div class="mt-12 text-center text-gray-400">
        <p class="text-lg">Beiträge kommen bald.</p>
        <p class="mt-2 text-sm">Hier werden Artikel zu Stundenplanung, Schulorganisation und KlassenTakt-Updates erscheinen.</p>
      </div>
    </div>
  </section>
</BaseLayout>
